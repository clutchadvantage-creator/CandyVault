# CandyVault backend environment
APP_ENV=development
DATABASE_URL=sqlite:///./candyvault.db
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
MAX_UPLOAD_MB=25
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Compatibility overrides normally left unset:
# DOCUMENT_UPLOAD_DIR=./uploads/documents
# MAX_DOCUMENT_SIZE_BYTES=26214400

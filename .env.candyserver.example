# Final candyserver production example. Copy to .env and adjust hostnames if needed.
APP_ENV=production
MAX_UPLOAD_MB=25
BACKEND_PORT=8000
FRONTEND_PORT=80

# These URLs are resolved by household browsers, not by Docker's internal DNS.
VITE_API_BASE_URL=http://candyserver:8000
CORS_ORIGINS=http://candyserver,http://candyserver.local

# Persistent container paths are fixed by docker-compose.yml:
# database: /opt/candyvault/database
# uploads:  /opt/candyvault/uploads
# backups:  /opt/candyvault/backups
# logs:    /opt/candyvault/logs
